{
  "name": "rr-monorepo",
  "description": "opiniated full stack monorepo boilerplate",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write --cache --ignore-path .prettierignore \"**/*.{js,cjs,mjs,jsx,ts,tsx,json,json5,md,yml,yaml,html,css,scss,less,gql,graphql,astro}\"",
    "format:check": "prettier --check --cache --ignore-path .prettierignore \"**/*.{js,cjs,mjs,jsx,ts,tsx,json,json5,md,yml,yaml,html,css,scss,less,gql,graphql,astro}\""
  },
  "keywords": ["monorepo", "fullstack", "boilerplate"],
  "author": "Rushil Rai",
  "license": "MIT",
  "packageManager": "pnpm@10.18.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.18.0"
  },
  "devDependencies": {
    "@types/node": "^24.7.0",
    "oxlint": "^1.50.0",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3"
  }
}
