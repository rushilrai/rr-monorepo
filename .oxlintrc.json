{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript"],
  "categories": {
    "correctness": "error"
  },
  "ignorePatterns": [
    "**/.turbo/**",
    "**/.next/**",
    "**/.expo/**",
    "apps/**/ios/**",
    "apps/**/android/**"
  ],
  "overrides": [
    {
      "files": ["**/*.{ts,tsx}"],
      "rules": {
        "typescript/no-explicit-any": "error"
      }
    }
  ]
}
